// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  owner
  manager
  seller
  backoffice
  warehouse_op
  warehouse_lead
  logistics_planner
  driver
  billing
  cashier
  collections
  finance
  auditor
}

model DeliveryZone {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  nombre      String   @db.VarChar(60)
  /// barrio | manual | predefinida
  tipo        String   @db.VarChar(20) @default("barrio")
  /// días de entrega separados por coma, e.g. "1,3,5"
  diasEntrega String?  @db.VarChar(20)
  /// horario preferido, e.g. "08:00-12:00"
  horario     String?  @db.VarChar(30)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientes Cliente[]

  @@index([tenantId])
}

model Cliente {
  id             Int      @id @default(autoincrement())
  codigo         Int      @unique
  rsocial        String   @db.VarChar(30)
  fantasia       String?  @db.VarChar(30)
  cuit           String?  @db.VarChar(14)
  condIva        String   @db.VarChar(1) // RI, Mono, CF, Exento
  domicilio      String?  @db.VarChar(40)
  localidad      String?  @db.VarChar(25)
  cpost          String?  @db.VarChar(8)
  telef          String?  @db.VarChar(25)
  email          String?  @db.VarChar(50)
  formaPago      Int?     // FK a FormaPago.id
  activo         Boolean  @default(true)
  // ── Financial fields (Issue #31) ──────────────────────────────────────────
  creditLimit    Decimal? @db.Decimal(14, 2)         // null = sin límite
  creditDays     Int      @default(0)                 // días de plazo habituales
  balance        Decimal  @db.Decimal(14, 2) @default(0)  // saldo acumulado
  balanceInicial Decimal  @db.Decimal(14, 2) @default(0)  // saldo al migrar datos
  score          Int      @default(50)               // score de pago 0-100
  suspended      Boolean  @default(false)            // bloquea nuevas ventas
  // ── Logistics (Issue #32) ─────────────────────────────────────────────────
  deliveryZoneId Int?
  deliveryZone   DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  // ──────────────────────────────────────────────────────────────────────────
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  facturas Factura[]
}

model Rubro {
  id    Int    @id @default(autoincrement())
  codigo Int   @unique
  nombre String @db.VarChar(20)

  articulos Articulo[]
}

model Articulo {
  id           Int    @id @default(autoincrement())
  codigo       Int    @unique
  descripcion  String @db.VarChar(30)
  rubroId      Int
  rubro        Rubro  @relation(fields: [rubroId], references: [id])
  condIva      String @db.VarChar(1) // IVA %: 1=21%, 2=10.5%, 3=Exento
  umedida      String @db.VarChar(6)
  precioLista1 Decimal @db.Decimal(14, 2)
  precioLista2 Decimal @db.Decimal(14, 2)
  costo        Decimal @db.Decimal(13, 2)
  stock        Int    @default(0)
  minimo       Int    @default(0)
  activo       Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facturaItems FacturaItem[]
}

model FormaPago {
  id    Int    @id @default(autoincrement())
  codigo Int   @unique
  descripcion String @db.VarChar(25)
  vto_dias Int  @default(0)
}

model Factura {
  id        Int       @id @default(autoincrement())
  fecha     DateTime
  tipo      String    @db.VarChar(1) // A, B, C, X
  prefijo   String    @db.VarChar(4)
  numero    Int
  clienteId Int
  cliente   Cliente   @relation(fields: [clienteId], references: [id])

  neto1     Decimal   @db.Decimal(14, 2) @default(0)  // Neto IVA 21%
  neto2     Decimal   @db.Decimal(14, 2) @default(0)  // Neto IVA 10.5%
  neto3     Decimal   @db.Decimal(14, 2) @default(0)  // Neto exento
  iva1      Decimal   @db.Decimal(14, 2) @default(0)  // IVA 21%
  iva2      Decimal   @db.Decimal(14, 2) @default(0)  // IVA 10.5%
  total     Decimal   @db.Decimal(14, 2) @default(0)

  formaPagoId Int?
  estado    String    @db.VarChar(1) @default("A") // A=activa, A=anulada
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items FacturaItem[]

  @@unique([tipo, prefijo, numero])
}

model FacturaItem {
  id        Int     @id @default(autoincrement())
  facturaId Int
  factura   Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  articuloId Int
  articulo   Articulo @relation(fields: [articuloId], references: [id])

  cantidad  Int       @default(1)
  precio    Decimal   @db.Decimal(14, 2)
  dscto     Decimal   @db.Decimal(5, 2) @default(0)
  subtotal  Decimal   @db.Decimal(14, 2)

  createdAt DateTime  @default(now())
}

model ParamEmpresa {
  id        Int     @id @default(autoincrement())
  nombre    String  @db.VarChar(40)
  cuit      String  @db.VarChar(14)
  domicilio String? @db.VarChar(40)
}

model Tenant {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(80)
  slug      String    @unique @db.VarChar(80)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users          AppUser[]
  auditEvents    AuditEvent[]
  notifications  Notification[]
  deliveryZones  DeliveryZone[]
}

model AppUser {
  id             Int       @id @default(autoincrement())
  tenantId       Int
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  username       String    @db.VarChar(60)
  passwordHash   String    @db.VarChar(255)
  role           UserRole
  active         Boolean   @default(true)
  scopeBranchIds Int[]     @default([])
  scopeWarehouseIds Int[]  @default([])
  scopeRouteIds  Int[]     @default([])
  scopeChannels  String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions      AppSession[]
  auditEvents   AuditEvent[]
  notifications Notification[]

  @@unique([tenantId, username])
}

model AppSession {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique @db.VarChar(64)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  userAgent   String?  @db.VarChar(255)
  ipAddress   String?  @db.VarChar(64)
}

model AuditEvent {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     Int?
  user       AppUser? @relation(fields: [userId], references: [id])
  action     String   @db.VarChar(80)
  resource   String   @db.VarChar(80)
  resourceId String?  @db.VarChar(120)
  ipAddress  String?  @db.VarChar(64)
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Notification {
  id        Int       @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  userId    Int       // recipient AppUser
  user      AppUser   @relation(fields: [userId], references: [id])
  /// credit_limit_exceeded | invoice_overdue | invoice_due_soon
  type      String    @db.VarChar(60)
  /// JSON payload: { clienteId?, facturaId?, amount?, limit?, rsocial? }
  payload   Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([tenantId, createdAt])
}
