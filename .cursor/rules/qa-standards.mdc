## 6. ACCESSIBILITY TESTING

### Standard: 100% automated a11y checks + manual keyboard navigation

**Automated A11y with axe-core:**
```typescript
// tests/a11y/accessibility.spec.ts
import { test, expect } from '@playwright/test'
import { injectAxe, checkA11y, getViolations } from 'axe-playwright'

test.describe('Accessibility Tests', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/login')
    await injectAxe(page)
  })

  test('login page has no a11y violations', async ({ page }) => {
    await checkA11y(page, null, {
      detailedReport: true,
      detailedReportOptions: { html: true }
    })
  })

  test('form inputs have associated labels', async ({ page }) => {
    const violations = await getViolations(page)
    const labelViolations = violations.filter(v => v.id === 'label')
    expect(labelViolations).toHaveLength(0)
  })

  test('color contrast is sufficient', async ({ page }) => {
    const violations = await getViolations(page)
    const contrastViolations = violations.filter(v => v.id === 'color-contrast')
    expect(contrastViolations).toHaveLength(0)
  })

  test('keyboard navigation works', async ({ page }) => {
    // Tab to first input
    await page.press('body', 'Tab')
    const emailInput = page.locator('input[name="email"]')
    await expect(emailInput).toBeFocused()

    // Tab to password input
    await page.press('body', 'Tab')
    const passwordInput = page.locator('input[name="password"]')
    await expect(passwordInput).toBeFocused()

    // Tab to submit button
    await page.press('body', 'Tab')
    const submitButton = page.locator('button[type="submit"]')
    await expect(submitButton).toBeFocused()

    // Submit with Enter
    await page.press('body', 'Enter')
    await expect(page).toHaveURL('/dashboard')
  })

  test('screen reader announces form errors', async ({ page }) => {
    // Fill with invalid data
    await page.fill('input[name="email"]', 'invalid-email')
    await page.click('button[type="submit"]')

    // Check for ARIA alert or aria-live region
    const errorAlert = page.locator('[role="alert"]')
    await expect(errorAlert).toBeVisible()
    expect(await errorAlert.textContent()).toContain('invalid')
  })
})
```

**Validation Checklist:**
```
✓ All form inputs have <label> elements
✓ All buttons have descriptive text (not just icons)
✓ Color contrast ratio ≥ 4.5:1 for normal text
✓ No color used as only means of conveying information
✓ Keyboard navigation works (Tab, Enter, Escape)
✓ Focus indicator visible
✓ Images have alt text
✓ Form errors announced to screen readers
✓ Loading states announced
✓ Modal dialogs properly marked with role="dialog"
```

