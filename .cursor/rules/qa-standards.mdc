## 3. INTEGRATION TESTING

### Standard: Vitest + real database testing with proper cleanup

**Integration Test Structure:**
```typescript
// tests/integration/api/clientes.test.ts
import { describe, it, expect, beforeEach, afterEach } from 'vitest'
import { PrismaClient } from '@prisma/client'
import { createApp } from '../../../server/createApp'

const prisma = new PrismaClient()

describe('POST /api/clientes', () => {
  let app: any
  let testTenantId: string
  let testUserId: string

  beforeEach(async () => {
    // Create test app instance
    app = createApp(process.env.DATABASE_URL)
    
    // Seed test data
    const tenant = await prisma.tenant.create({
      data: { name: 'Test Tenant' }
    })
    testTenantId = tenant.id

    const user = await prisma.appUser.create({
      data: {
        tenantId: testTenantId,
        email: 'test@test.com',
        passwordHash: 'hashed_password',
        role: 'ADMIN'
      }
    })
    testUserId = user.id
  })

  afterEach(async () => {
    // Clean up test data
    await prisma.cliente.deleteMany({ where: { tenantId: testTenantId } })
    await prisma.appUser.deleteMany({ where: { tenantId: testTenantId } })
    await prisma.tenant.deleteMany({ where: { id: testTenantId } })
  })

  it('should create client with valid data', async () => {
    const response = await app.request('POST', '/api/clientes', {
      headers: { 'X-Tenant-ID': testTenantId, 'X-User-ID': testUserId },
      body: {
        nombre: 'Test Client',
        cuit: '20123456789',
        email: 'client@test.com'
      }
    })

    expect(response.status).toBe(201)
    expect(response.body.data.id).toBeDefined()
    expect(response.body.data.nombre).toBe('Test Client')

    // Verify in database
    const client = await prisma.cliente.findUnique({
      where: { id: response.body.data.id }
    })
    expect(client).toBeDefined()
  })

  it('should reject invalid CUIT', async () => {
    const response = await app.request('POST', '/api/clientes', {
      headers: { 'X-Tenant-ID': testTenantId, 'X-User-ID': testUserId },
      body: {
        nombre: 'Test Client',
        cuit: 'INVALID',
        email: 'client@test.com'
      }
    })

    expect(response.status).toBe(400)
    expect(response.body.error.code).toBe('INVALID_CUIT')
  })

  it('should enforce multi-tenant isolation', async () => {
    // Create client in tenant A
    const otherTenant = await prisma.tenant.create({
      data: { name: 'Other Tenant' }
    })

    const client = await prisma.cliente.create({
      data: {
        tenantId: otherTenant.id,
        nombre: 'Other Tenant Client',
        cuit: '30123456789'
      }
    })

    // Try to access from tenant B
    const response = await app.request('GET', `/api/clientes/${client.id}`, {
      headers: { 'X-Tenant-ID': testTenantId, 'X-User-ID': testUserId }
    })

    expect(response.status).toBe(403)
  })
})
```

**Best Practices:**
- ✅ Use real database (not mocks)
- ✅ Isolate each test (no interdependencies)
- ✅ Clean up after each test
- ✅ Test both success and failure paths
- ✅ Verify database state, not just API response
- ✅ Test error handling and edge cases
- ❌ Don't depend on test execution order
- ❌ Don't share database state between tests

