## 9. SECURITY TESTING

### Standard: Automated SAST + manual DAST + dependency scanning

**SAST (Static Application Security Testing):**
```bash
# Check for hardcoded secrets
git-secrets --scan

# ESLint security plugin
eslint --ext .ts,.tsx src/

# Dependency vulnerability scanning
npm audit
snyk test

# Type checking (catches some security issues)
tsc --noEmit
```

**API Security Tests:**
```typescript
// tests/security/api-security.spec.ts
import { test, expect } from '@playwright/test'

test.describe('API Security', () => {
  test('GET /api/clientes requires authentication', async ({ request }) => {
    const res = await request.get('/api/clientes')
    expect(res.status()).toBe(401)
  })

  test('XSS prevention: HTML escaped in responses', async ({ request }) => {
    const res = await request.post('/api/clientes', {
      data: {
        nombre: '<script>alert("XSS")</script>'
      }
    })
    
    const body = await res.json()
    expect(body.nombre).not.toContain('<script>')
  })

  test('SQL injection prevented (parameterized queries)', async ({ request }) => {
    const res = await request.get('/api/clientes?search="; DROP TABLE clientes; --')
    expect(res.status()).toBe(200)
    
    // Verify database still has data
    const clientes = await request.get('/api/clientes')
    const clientesData = await clientes.json()
    expect(clientesData.data.length).toBeGreaterThan(0)
  })

  test('Rate limiting: 100 requests/min enforced', async ({ request }) => {
    // Fire 101 requests
    for (let i = 0; i < 101; i++) {
      const res = await request.get('/api/clientes')
      if (i === 100) {
        expect(res.status()).toBe(429) // Too Many Requests
      }
    }
  })

  test('CSRF tokens validated', async ({ request }) => {
    // POST without CSRF token
    const res = await request.post('/api/clientes', {
      data: { nombre: 'Test' }
    })
    
    expect(res.status()).toBeGreaterThanOrEqual(400)
  })
})
```

