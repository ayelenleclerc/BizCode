**Test Setup/Teardown:**
```typescript
// tests/setup.ts
import { PrismaClient } from '@prisma/client'
import { testTenant, testUser, testClient, testArticle } from './fixtures/test-data'

const prisma = new PrismaClient()

beforeEach(async () => {
  // Create test tenant
  await prisma.tenant.create({ data: testTenant })
  
  // Create test user
  await prisma.appUser.create({ data: testUser })
  
  // Create test data
  await prisma.cliente.create({ data: testClient })
  await prisma.articulo.create({ data: testArticle })
})

afterEach(async () => {
  // Clean up in reverse order (respect foreign keys)
  await prisma.facturaItem.deleteMany({ where: { tenantId: testTenant.id } })
  await prisma.factura.deleteMany({ where: { tenantId: testTenant.id } })
  await prisma.articulo.deleteMany({ where: { tenantId: testTenant.id } })
  await prisma.cliente.deleteMany({ where: { tenantId: testTenant.id } })
  await prisma.appUser.deleteMany({ where: { tenantId: testTenant.id } })
  await prisma.tenant.deleteMany({ where: { id: testTenant.id } })
  
  await prisma.$disconnect()
})
```

