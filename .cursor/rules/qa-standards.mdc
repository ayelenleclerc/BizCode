## 2. UNIT TESTING

### Standard: Vitest with comprehensive assertions and clear test structure

**Test File Organization:**
```
src/
├── lib/
│   ├── validators.ts
│   └── validators.test.ts     (same folder, .test.ts suffix)
├── components/
│   ├── Button.tsx
│   └── Button.test.tsx
└── contexts/
    ├── AuthContext.tsx
    └── AuthContext.test.tsx

tests/
├── unit/                       (if tests in separate folder)
│   ├── lib/
│   │   └── validators.test.ts
│   └── utils/
│       └── formatting.test.ts
├── integration/
│   └── api/
└── e2e/
    └── critical-paths.spec.ts
```

**Test Structure:**
```typescript
import { describe, it, expect, beforeEach, afterEach } from 'vitest'
import { validateCUIT } from '../validators'

describe('validateCUIT', () => {
  describe('valid inputs', () => {
    it('should accept valid CUIT', () => {
      const result = validateCUIT('20123456789')
      expect(result).toBe(true)
    })

    it('should accept CUIT with spaces', () => {
      const result = validateCUIT('20 123 456 789')
      expect(result).toBe(true)
    })
  })

  describe('invalid inputs', () => {
    it('should reject CUIT with invalid checksum', () => {
      const result = validateCUIT('20123456780')
      expect(result).toBe(false)
    })

    it('should reject non-numeric CUIT', () => {
      const result = validateCUIT('20ABC456789')
      expect(result).toBe(false)
    })

    it('should reject null/undefined', () => {
      expect(validateCUIT(null)).toBe(false)
      expect(validateCUIT(undefined)).toBe(false)
    })
  })

  describe('edge cases', () => {
    it('should handle empty string', () => {
      const result = validateCUIT('')
      expect(result).toBe(false)
    })
  })
})
```

**Best Practices:**
- ✅ One assertion per test (or tightly related)
- ✅ Descriptive test names (what should happen)
- ✅ Arrange-Act-Assert pattern
- ✅ Test behavior, not implementation
- ✅ Mock external dependencies
- ✅ Use fixtures for complex data
- ❌ Don't test third-party libraries
- ❌ Don't have shared state between tests
- ❌ Don't use magic numbers (use named constants)

**Coverage Enforcement:**
```javascript
// vitest.config.ts
export default defineConfig({
  test: {
    coverage: {
      provider: 'v8',
      reporter: ['text', 'html', 'json'],
      lines: 90,
      functions: 90,
      branches: 90,
      statements: 90,
      exclude: [
        'node_modules/',
        'dist/',
        'tests/',
        '**/*.test.ts',
        '**/*.spec.ts',
        '**/types.ts'
      ]
    }
  }
})
```

