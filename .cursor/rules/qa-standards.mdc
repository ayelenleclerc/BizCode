## 8. PERFORMANCE TESTING

### Standard: Load testing with k6, baseline tracking, and alert thresholds

**Load Test Script (k6):**
```javascript
// tests/performance/api-load.js
import http from 'k6/http'
import { check, sleep, group } from 'k6'
import { Rate, Trend, Counter } from 'k6/metrics'

// Custom metrics
const errorRate = new Rate('errors')
const duration = new Trend('duration')
const successCount = new Counter('success')

export const options = {
  stages: [
    { duration: '30s', target: 10 },   // Ramp up
    { duration: '5m', target: 10 },    // Stay at load
    { duration: '30s', target: 0 }     // Ramp down
  ],
  thresholds: {
    'http_req_duration': ['p(95)<500', 'p(99)<1000'],
    'http_req_failed': ['rate<0.001'],
    'errors': ['rate<0.01']
  }
}

export default function() {
  group('GET /clientes', () => {
    const res = http.get('http://localhost:3000/api/clientes')
    
    const success = check(res, {
      'status is 200': (r) => r.status === 200,
      'response time < 200ms': (r) => r.timings.duration < 200,
      'has data': (r) => JSON.parse(r.body).data !== undefined
    })

    errorRate.add(!success)
    duration.add(res.timings.duration)
    if (success) successCount.add(1)
  })

  group('POST /clientes', () => {
    const res = http.post('http://localhost:3000/api/clientes', {
      nombre: 'Test Client',
      cuit: '20123456789',
      email: 'test@test.com'
    })

    check(res, {
      'status is 201': (r) => r.status === 201,
      'response time < 500ms': (r) => r.timings.duration < 500
    })
  })

  sleep(1)
}
```

**Performance Targets:**
```
API Endpoints:
├── GET /clientes:     <200ms (p95)
├── GET /articulos:    <200ms (p95)
├── GET /facturas:     <300ms (p95)
├── POST /clientes:    <500ms (p95)
├── POST /articulos:   <500ms (p95)
├── POST /facturas:    <1000ms (p95)
└── GET /health:       <50ms (p95)

Error Rate:
├── P95 latency:       <500ms
├── P99 latency:       <1000ms
└── Error rate:        <0.1%

Load Profile:
├── 10 concurrent users minimum
├── Ramp up: 0 → 10 in 30 seconds
├── Maintain: 10 users for 5 minutes
└── Ramp down: 10 → 0 in 30 seconds
```

