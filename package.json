{
  "name": "bizcode",
  "version": "0.1.0",
  "private": true,
  "description": "**BizCode** is a cross-platform desktop application for commercial management (customers, products, invoicing). It is built with Tauri 1.5 + React 18 + Express 5 + Prisma 5 + PostgreSQL, and developed to meet ISO 9001:2015, ISO/IEC 12207, and ISO/IEC 25010 quality standards.",
  "homepage": "https://github.com/ayelenleclerc/BizCode#readme",
  "bugs": {
    "url": "https://github.com/ayelenleclerc/BizCode/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayelenleclerc/BizCode.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "postcss.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "server": "tsx server/main.ts",
    "dev:vite": "vite",
    "dev": "tauri dev",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build:web": "vite build",
    "build": "tauri build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src server tests e2e scripts/github/plan-sync scripts/github/plan-sync-main.ts scripts/github/plan-validate-main.ts scripts/github/plan-approve-main.ts --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src server tests e2e scripts/github/plan-sync scripts/github/plan-sync-main.ts scripts/github/plan-validate-main.ts scripts/github/plan-approve-main.ts --ext .ts,.tsx --fix --max-warnings 0",
    "plan:sync": "tsx scripts/github/plan-sync-main.ts",
    "plan:validate": "tsx scripts/github/plan-validate-main.ts",
    "plan:approve": "tsx scripts/github/plan-approve-main.ts",
    "check:i18n": "tsx scripts/check-i18n.ts",
    "check:docs-map": "tsx scripts/check-docs-locale-map.ts",
    "docs:generate-iso-stubs": "node scripts/generate-iso-controlled-docs.mjs",
    "sbom:generate": "cyclonedx-npm --output-file docs/evidence/sbom-cyclonedx.json --package-lock-only --ignore-npm-errors --omit dev",
    "sbom:generate:full": "cyclonedx-npm --output-file docs/evidence/sbom-cyclonedx-full.json --package-lock-only --ignore-npm-errors",
    "docs:extract-schemas": "tsx scripts/extract-openapi-schemas.ts",
    "docs:schemas-md": "jsonschema2md -d docs/generated/schema-json -o docs/generated/schema-md -x -",
    "docs:openapi-md": "tsx scripts/generate-openapi-markdown.ts",
    "docs:typedoc": "typedoc --options typedoc.json",
    "docs:sbom": "npm run sbom:generate",
    "docs:generate": "npm run docs:extract-schemas && npm run docs:schemas-md && npm run docs:openapi-md && npm run docs:typedoc && npm run docs:sbom",
    "bootstrap:superadmin": "tsx scripts/bootstrap-superadmin.ts",
    "migrate:dbf": "tsx scripts/migrate-from-dbf.ts",
    "inspect:dbf-all": "tsx scripts/inspect-dbf-all.ts",
    "release": "semantic-release"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tauri-apps/api": "~1.5.6",
    "axios": "^1.14.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "i18next": "^26.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.3",
    "react-hotkeys-hook": "^4.5.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.22.3",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1",
    "yaml": "^2.8.3",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@adobe/jsonschema2md": "^8.0.11",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.0",
    "@prisma/client": "^5.22.0",
    "@scalar/openapi-to-markdown": "^0.4.16",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@tauri-apps/cli": "~1.5.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest-axe": "^3.5.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "dbffile": "^1.12.0",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.35",
    "prisma": "^5.22.0",
    "semantic-release": "^24.2.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
