{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "activo": {
      "default": true,
      "type": "boolean"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "diasEntrega": {
      "description": "Comma-separated delivery day numbers, e.g. \"1,3,5\"",
      "nullable": true,
      "type": "string"
    },
    "horario": {
      "description": "Preferred time window, e.g. \"08:00-12:00\"",
      "nullable": true,
      "type": "string"
    },
    "id": {
      "type": "integer"
    },
    "nombre": {
      "type": "string"
    },
    "tenantId": {
      "type": "integer"
    },
    "tipo": {
      "default": "barrio",
      "enum": [
        "barrio",
        "manual",
        "predefinida"
      ],
      "type": "string"
    },
    "updatedAt": {
      "format": "date-time",
      "type": "string"
    }
  },
  "title": "DeliveryZone",
  "type": "object"
}
